{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/compress-image/layout,_N_T_/compress-image/page,_N_T_/compress-image"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/compress-image/__PAGE__",
    "/compress-image",
    "/_index",
    "/_head"
  ]
}